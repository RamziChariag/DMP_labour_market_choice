             total_local_count = total_local_count + 1
          end if
       end do
    end do
    
    ! 1 months of unemployment
    do i = 1,nr
       do j = 1,ns-2
          if ( ( E_monthly(i,j) .eq. 1) &
               .and. ( E_monthly(i,j+1) .eq. 0) &
               .and. ( E_monthly(i,j+2) .eq. 1) &
               .and. ( W_monthly(i,j+2) .gt. 0.0_wp) &
               .and. (W_monthly(i,j) .gt. 0.0_wp) ) then
             total_local_sum = total_local_sum + ( log(W_monthly(i,j+2)) - log(W_monthly(i,j))  )
             total_local_count = total_local_count + 1
          end if
       end do
    end do
    
    ! Mean Wage Changes via unemployment
    tmp_local_mean = total_local_sum / real(total_local_count, wp)

    !!! Variance of wage change via unemployment
    !! Mean wage changes given unemployment spell
    ! twelve months of unemployment
    do i = 1,nr
       do j = 1,ns-13
          if ( ( E_monthly(i,j) .eq. 1) &
               .and. ( E_monthly(i,j+1) .eq. 0) &
               .and. ( E_monthly(i,j+2) .eq. 0) &
               .and.( E_monthly(i,j+3) .eq. 0) &
               .and.( E_monthly(i,j+4) .eq. 0) &
               .and.( E_monthly(i,j+5) .eq. 0) &
               .and.( E_monthly(i,j+6) .eq. 0) &
               .and.( E_monthly(i,j+7) .eq. 0) &
               .and.( E_monthly(i,j+8) .eq. 0) &
               .and.( E_monthly(i,j+9) .eq. 0) &
               .and.( E_monthly(i,j+10) .eq. 0) &
               .and.( E_monthly(i,j+11) .eq. 0) &
               .and.( E_monthly(i,j+12) .eq. 0) &
               .and. ( E_monthly(i,j+13) .eq. 1) &
               .and. ( W_monthly(i,j+13) .gt. 0.0_wp) &
               .and. (W_monthly(i,j) .gt. 0.0_wp) ) then
             total_local_sum_of_square  = total_local_sum_of_square + ( log(W_monthly(i,j+13)) - log(W_monthly(i,j)) - tmp_local_mean )**2
          end if
       end do
    end do

    ! 11 months of unemployment
    do i = 1,nr
       do j = 1,ns-12
          if ( ( E_monthly(i,j) .eq. 1) &
               .and. ( E_monthly(i,j+1) .eq. 0) &
               .and. ( E_monthly(i,j+2) .eq. 0) &
               .and.( E_monthly(i,j+3) .eq. 0) &
               .and.( E_monthly(i,j+4) .eq. 0) &
               .and.( E_monthly(i,j+5) .eq. 0) &
               .and.( E_monthly(i,j+6) .eq. 0) &
               .and.( E_monthly(i,j+7) .eq. 0) &
               .and.( E_monthly(i,j+8) .eq. 0) &
               .and.( E_monthly(i,j+9) .eq. 0) &
               .and.( E_monthly(i,j+10) .eq. 0) &
               .and.( E_monthly(i,j+11) .eq. 0) &
               .and.( E_monthly(i,j+12) .eq. 1) &
               .and. ( W_monthly(i,j+12) .gt. 0.0_wp) &
               .and. (W_monthly(i,j) .gt. 0.0_wp) ) then
             total_local_sum_of_square = total_local_sum_of_square + ( log(W_monthly(i,j+12)) - log(W_monthly(i,j))   - tmp_local_mean )**2
          end if
       end do
    end do

    ! 10 months of unemployment
    do i = 1,nr
       do j = 1,ns-11
          if ( ( E_monthly(i,j) .eq. 1) &
               .and. ( E_monthly(i,j+1) .eq. 0) &
