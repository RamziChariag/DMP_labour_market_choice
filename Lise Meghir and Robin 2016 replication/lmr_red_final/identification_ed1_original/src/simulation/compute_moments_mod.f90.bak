          end if
       end do
    end do
    
    ! 7 months of unemployment
    do i = 1,nr
       do j = 1,ns-8
          if ( ( E_monthly(i,j) .eq. 1) &
               .and. ( E_monthly(i,j+1) .eq. 0) &
               .and. ( E_monthly(i,j+2) .eq. 0) &
               .and.( E_monthly(i,j+3) .eq. 0) &
               .and.( E_monthly(i,j+4) .eq. 0) &
               .and.( E_monthly(i,j+5) .eq. 0) &
