               .and.( E_monthly(i,j+11) .eq. 0) &
               .and.( E_monthly(i,j+12) .eq. 1) &
               .and. ( W_monthly(i,j+12) .gt. 0.0_wp) &
               .and. (W_monthly(i,j) .gt. 0.0_wp) ) then
             total_local_sum = total_local_sum + ( log(W_monthly(i,j+12)) - log(W_monthly(i,j))  )
             total_local_count = total_local_count + 1
          end if
       end do
    end do

    ! 10 months of unemployment
    do i = 1,nr
       do j = 1,ns-11
          if ( ( E_monthly(i,j) .eq. 1) &
