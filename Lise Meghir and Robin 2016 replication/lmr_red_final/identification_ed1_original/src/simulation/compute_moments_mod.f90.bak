             total_local_sum_of_square = total_local_sum_of_square + ( log(W_monthly(i,j+7)) - log(W_monthly(i,j))  - tmp_local_mean )**2
          end if
       end do
    end do
    
    ! 5 months of unemployment
    do i = 1,nr
       do j = 1,ns-6
          if ( ( E_monthly(i,j) .eq. 1) &
               .and. ( E_monthly(i,j+1) .eq. 0) &
               .and. ( E_monthly(i,j+2) .eq. 0) &
               .and.( E_monthly(i,j+3) .eq. 0) &
               .and.( E_monthly(i,j+4) .eq. 0) &
               .and.( E_monthly(i,j+5) .eq. 0) &
               .and.( E_monthly(i,j+6) .eq. 1) &
               .and. ( W_monthly(i,j+6) .gt. 0.0_wp) &
               .and. (W_monthly(i,j) .gt. 0.0_wp) ) then
             total_local_sum_of_square = total_local_sum_of_square + ( log(W_monthly(i,j+6)) - log(W_monthly(i,j))  - tmp_local_mean )**2
          end if
       end do
    end do
    
    ! 4 months of unemployment
    do i = 1,nr
       do j = 1,ns-5
          if ( ( E_monthly(i,j) .eq. 1) &
               .and. ( E_monthly(i,j+1) .eq. 0) &
               .and. ( E_monthly(i,j+2) .eq. 0) &
               .and.( E_monthly(i,j+3) .eq. 0) &
               .and.( E_monthly(i,j+4) .eq. 0) &
               .and.( E_monthly(i,j+5) .eq. 1) &
               .and. ( W_monthly(i,j+5) .gt. 0.0_wp) &
               .and. (W_monthly(i,j) .gt. 0.0_wp) ) then
             total_local_sum_of_square = total_local_sum_of_square + ( log(W_monthly(i,j+5)) - log(W_monthly(i,j))  - tmp_local_mean )**2
          end if
       end do
    end do
    
    ! 3 months of unemployment
    do i = 1,nr
       do j = 1,ns-4
          if ( ( E_monthly(i,j) .eq. 1) &
               .and. ( E_monthly(i,j+1) .eq. 0) &
               .and. ( E_monthly(i,j+2) .eq. 0) &
               .and.( E_monthly(i,j+3) .eq. 0) &
               .and.( E_monthly(i,j+4) .eq. 1) &
               .and. ( W_monthly(i,j+4) .gt. 0.0_wp) &
               .and. (W_monthly(i,j) .gt. 0.0_wp) ) then
             total_local_sum_of_square = total_local_sum_of_square + ( log(W_monthly(i,j+4)) - log(W_monthly(i,j))  - tmp_local_mean )**2
          end if
       end do
    end do
    
    ! 2 months of unemployment
    do i = 1,nr
       do j = 1,ns-3
          if ( ( E_monthly(i,j) .eq. 1) &
               .and. ( E_monthly(i,j+1) .eq. 0) &
               .and. ( E_monthly(i,j+2) .eq. 0) &
               .and.( E_monthly(i,j+3) .eq. 1) &
               .and. ( W_monthly(i,j+3) .gt. 0.0_wp) &
               .and. (W_monthly(i,j) .gt. 0.0_wp) ) then
             total_local_sum_of_square = total_local_sum_of_square + ( log(W_monthly(i,j+3)) - log(W_monthly(i,j))  - tmp_local_mean )**2
          end if
       end do
    end do
    
    ! 1 months of unemployment
    do i = 1,nr
       do j = 1,ns-2
          if ( ( E_monthly(i,j) .eq. 1) &
               .and. ( E_monthly(i,j+1) .eq. 0) &
               .and. ( E_monthly(i,j+2) .eq. 1) &
               .and. ( W_monthly(i,j+2) .gt. 0.0_wp) &
               .and. (W_monthly(i,j) .gt. 0.0_wp) ) then
             total_local_sum_of_square = total_local_sum_of_square + ( log(W_monthly(i,j+2)) - log(W_monthly(i,j))  - tmp_local_mean )**2
          end if
       end do
    end do
    
    ! Mean Wage Changes via unemployment
    tmp_local_var = total_local_sum_of_square / real(total_local_count, wp)

    moms%DwEUE_var = tmp_local_var
    moms%DwEUE_bar = tmp_local_mean 

    ! Create year over year change in average monthly earnings over the
    ! year (total earnings over the year divided by the number of months
    ! worked )
    ! write(*,*) "Computing final moments"

    ! Now, calculate the UNCONDITIONAL mean, variance, growth , varianc ofo growwha nd 1st and 2nd autocovariances of growth.
    ! Use the year 11,12,13,14 (ie, the years just aftet the first 10 in teh labour markket)

    w_monthly = merge(w_monthly, 0.0_wp, E_monthly .eq. 1)

    do j = 1,years
       w_t(:,j) = sum(w_monthly(:,(1+12*(j-1)) : 12*j) ,2)
       empl_t(:,j) =  sum(E_monthly(:,(1+12*(j-1)) : 12*j) ,2)
    end do

    !! only use the next line with conditioning on quantile
    !    usable = usable .and. line_mask

! Calculate the first 4 moments of the crossectional distrubution of
! wages in first, middle and last year of simulation
    usable = .FALSE.
    usable = ( (empl_t .gt. 0) .and. (w_t .gt. 0.0_wp))
    w_year =   merge(log(w_t   / real(empl_t   ,wp)), 0.0_wp ,  usable)
    call momentsVecWithMask(w_year(:,2) , usable(:,2),  moms%y1_mean_w , moms%y1_var_w)
    call SkewKurtVecWithMask(w_year(:,2) ,usable(:,2), moms%y1_mean_w , moms%y1_var_w, moms%y1_skewness, moms%y1_kurtosis)

    call momentsVecWithMask(w_year(:,12) , usable(:,12),  moms%y11_mean_w , moms%y11_var_w)
    call SkewKurtVecWithMask(w_year(:,12) ,usable(:,12), moms%y11_mean_w , moms%y11_var_w, moms%y11_skewness, moms%y11_kurtosis)

    call momentsVecWithMask(w_year(:,22) , usable(:,22),  moms%y21_mean_w , moms%y21_var_w)
    call SkewKurtVecWithMask(w_year(:,22) ,usable(:,22), moms%y21_mean_w , moms%y21_var_w, moms%y21_skewness, moms%y21_kurtosis)

! Centre wage data to have zero mean each year (remove age effect)
    do j = 1,years
       call momentsVecWithMask(w_year(:,j) , usable(:,j),  tmp_local_mean , tmp_local_var )
       w_year(:,j) = w_year(:,j) - tmp_local_mean
    end do

    ! Calculate first differences
    deallocate ( usable )
    allocate ( usable(nr, years-1 ))
    
    usable = .FALSE.
    do j=1,years-1
       usable(:,j) = ( (empl_t(:,j+1) .gt. 0) .and. (empl_t(:,j) .gt. 0) )
    end do
    
    do j=1,years-1
       Dw_year(:,j) = merge(w_year(:,j+1)-w_year(:,j), 0.0_wp, usable(:,j))
    end do
! given the panel structure of the data it is easier to calculate the
! covariances in the following "messy" way rather than calling the
! moments function

    total_local_count = 0
    total_local_sum = 0.0_wp
    total_local_sum_of_square = 0.0_wp
    tmp_local_mean = 0.0_wp

    ! calculate mean
    do i=1,nr
       do j=1,years-1
          if ( usable(i,j) ) then
             total_local_count = total_local_count + 1
             total_local_sum = total_local_sum + Dw_year(i,j)
          end if
       end do
    end do
    tmp_local_mean = total_local_sum / real(total_local_count, wp)

    total_local_count = 0
    total_local_sum = 0.0_wp
    total_local_sum_of_square = 0.0_wp

    ! calculate variance
    do i=1,nr
       do j=1,years-1
          if ( usable(i,j) ) then
             total_local_count = total_local_count + 1
             total_local_sum_of_square = total_local_sum_of_square + (Dw_year(i,j) - tmp_local_mean )**2
          end if
       end do
    end do
    moms%ALL_var_Dw = total_local_sum_of_square / real(total_local_count, wp)

    total_local_count = 0
    total_local_sum = 0.0_wp
    total_local_sum_of_square = 0.0_wp

    ! calculate cov(Dw, L.Dw)
    do i=1,nr
       do j=1,years-2
          if ( usable(i,j) .and. usable(i,j+1) ) then
             total_local_count = total_local_count + 1
             total_local_sum_of_square = total_local_sum_of_square + (Dw_year(i,j) - tmp_local_mean )*(Dw_year(i,j+1) - tmp_local_mean )
          end if
       end do
    end do
    moms%ALL_cov_DwDwL1 = total_local_sum_of_square / real(total_local_count, wp)

    total_local_count = 0
    total_local_sum = 0.0_wp
    total_local_sum_of_square = 0.0_wp

    ! calculate cov(Dw, L2.Dw)
    do i=1,nr
       do j=1,years-3
          if ( usable(i,j) .and. usable(i,j+2) ) then
             total_local_count = total_local_count + 1
             total_local_sum_of_square = total_local_sum_of_square + (Dw_year(i,j) - tmp_local_mean )*(Dw_year(i,j+2) - tmp_local_mean )
          end if
       end do
    end do
    moms%ALL_cov_DwDwL2 = total_local_sum_of_square / real(total_local_count, wp)


    ! clean up
        deallocate( max_wage  )
        deallocate( worker_type  )
        deallocate( W_monthly )
        deallocate( E_monthly )
        deallocate( E_monthly_all )
        deallocate( F_monthly )
        deallocate( DJ )
        deallocate( E2E  )
        deallocate( w_t )
        deallocate( empl_t )
        deallocate( usable )
        deallocate( tmp_den )
        deallocate( tmp_num )
        deallocate( w_year )
        deallocate( Dw_year )

end subroutine computemoments

    !----------------------------------------
    ! HELPERS
    !----------------------------------------

    subroutine computeMeanLogWageChangeWithMask(E_Status, unemployment_span, wages, lmean, lvar, lcount, line_mask)
      implicit none
      logical,allocatable :: time_index(:,:)
      logical, intent(IN) :: line_mask(:)
      integer, intent(in) :: unemployment_span
      integer, intent(IN) :: E_Status(:,:)
      real(wp), intent(IN) :: wages(:,:)
      integer :: n,end,nr
      real(wp) , intent(OUT) :: lmean,lvar
      integer :: ir, it ,i
	  integer, optional :: lcount

      !--------------------------------------
      ! Create wage changes for job losers
      ! unemployment_span months unemployed
      !--------------------------------------
      n = size(E_status,2)
      nr = size(E_status , 1)
      end = n - unemployment_span -1  ! we need the -1 to have EUUUUUUUUUUUUE (up to 12 periods of unemployment then employment)

      allocate( time_index(nr , end) )

      !EMPLOYED AT FIRST
      time_index = (E_Status(:,1:end) .eq. 1)

      !UNEMPLOYED FOR unemployment_span PERIODS
      do i=1,unemployment_span
         time_index = time_index .and. (E_Status(:, (1 + i):(end + i) )  .eq.  0)
      end do

      !EMPLOYED AT LAST
      time_index = time_index .and. (E_Status(:,(1 + unemployment_span+1):(end + unemployment_span+1))  .eq.  1)
	  time_index = time_index .and. spread(line_mask,2,end)

      call computeWageMomentsWithMask(time_index , unemployment_span + 1 , wages, lmean , lvar,lcount)

      !CLEANING UP
      deallocate( time_index )

    end subroutine computeMeanLogWageChangeWithMask

    subroutine computeWageMomentsWithMask(mask , lag , wages , lmean , lvar, elcount)
        implicit none
        logical, intent(IN) :: mask(:,:)
        real(wp), intent(IN) :: wages(:,:)
        real(wp), intent(OUT) :: lmean, lvar
        integer, intent(IN) :: lag
        integer :: nr , end , ir ,it ,nt
        integer,intent(out),optional :: elcount
        integer :: lcount
        real(wp) :: val

        lcount = 0
        nr = size(mask,1)
        nt = size(mask,2)
        val   = 0.0_wp
        lmean = 0.0_wp
        lvar = 0.0_wp

        do ir = 1,nr
            do it = 1,nt
                if (mask(ir,it))  then
                    val = log( wages(ir, it + lag)) - log( wages(ir, it))
                    lmean = lmean + val
                    lcount = lcount +1
                end if
            end do
        end do

        lmean = lmean / real(lcount, wp)

        do ir = 1,nr
            do it = 1,nt
                if (mask(ir,it))  then
                    val = ((log( wages(ir, it + lag)) - log( wages(ir, it))) - lmean )**2
                    lvar = lvar + val
                end if
            end do
        end do

        lvar = lvar / real(lcount, wp) 

        if (present(elcount)) then
           elcount = lcount
        end if

    end subroutine computeWageMomentsWithMask

	subroutine computeMatchDistribution(s,p,h_xy,l,b)
	    implicit none
    	type (SimulationWorkerPanel) , intent(IN) :: s
    	type (ExogenousParameters),    intent(in)    :: p
		integer, intent(IN) :: l,b
		real(wp), intent(INOUT) :: h_xy(:,:)

		integer :: nr, nt , lcount
		integer :: ir , it

		nr = size(s%status_rt , 1)
		nt = size(s%status_rt , 2)

		h_xy = 0.0_wp
		lcount = 0

		do it = l, b
			do ir= 1, nr
				if (s%status_rt(ir,it) .eq. 1) then
					h_xy(s%worker_type_r(ir) , s%firm_type_rt(ir,it)) = h_xy(s%worker_type_r(ir) , s%firm_type_rt(ir,it)) +1
					lcount = lcount +1
				end if
			end do
		end do

		h_xy = h_xy / real(lcount,wp)

	end subroutine computeMatchDistribution



end module compute_moments_mod

