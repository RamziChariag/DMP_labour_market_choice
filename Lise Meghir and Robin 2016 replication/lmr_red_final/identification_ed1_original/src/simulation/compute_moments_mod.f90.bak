               .and.( E_monthly(i,j+8) .eq. 1) &
               .and. ( W_monthly(i,j+8) .gt. 0.0_wp) &
               .and. (W_monthly(i,j) .gt. 0.0_wp) ) then
             total_local_sum_of_square = total_local_sum_of_square + ( log(W_monthly(i,j+8)) - log(W_monthly(i,j))  - tmp_local_mean )**2
          end if
       end do
    end do
    
    ! 6 months of unemployment
    do i = 1,nr
       do j = 1,ns-7
          if ( ( E_monthly(i,j) .eq. 1) &
               .and. ( E_monthly(i,j+1) .eq. 0) &
               .and. ( E_monthly(i,j+2) .eq. 0) &
               .and.( E_monthly(i,j+3) .eq. 0) &
